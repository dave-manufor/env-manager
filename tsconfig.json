{
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "esnext",
    "target": "ES2022",
    "moduleDetection": "force",
    "outDir": "build",
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "types": ["jest", "node"]
  },
  "include": ["src", "test", "index.ts"],
  "exclude": ["node_modules", "build"]
}
